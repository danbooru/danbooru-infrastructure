RAILS_ENV=production
RAILS_SERVE_STATIC_FILES=true

PUMA_BIND=tcp://0.0.0.0:3000?low_latency=true&backlog=1024
PUMA_METRICS_URL=tcp://127.0.0.1:9393
PUMA_MIN_THREADS=1
PUMA_MAX_THREADS=5
PUMA_WORKERS=4

DANBOORU_CONFIG_FILE=/etc/danbooru/danbooru_local_config.rb
DANBOORU_APP_NAME=Donmai
DANBOORU_CANONICAL_APP_NAME=Donmai
DANBOORU_CANONICAL_URL=https://donmai.moe
DANBOORU_SITE_TAGLINE=Anime Image Board
DANBOORU_SITE_DESCRIPTION=Donmai.moe is an anime and manga fanart search engine.
DANBOORU_CONTACT_EMAIL=webmaster@donmai.moe
DANBOORU_PAGE_NOT_FOUND_POOL_ID=16069
DANBOORU_SMALL_SEARCH_THRESHOLD=30000

DANBOORU_TWITTER_USERNAME=

DANBOORU_REDIS_URL=redis://redis-0.redis-svc.danbooru.svc.cluster.local:6379
DANBOORU_IQDB_URL=http://iqdb.danbooru.svc.cluster.local:5588
DANBOORU_AUTOTAGGER_URL=http://autotagger.danbooru.svc.cluster.local
DANBOORU_RECOMMENDER_SERVER=http://recommender.danbooru.svc.cluster.local:5000
DANBOORU_REPORTBOORU_SERVER=https://isshiki.donmai.us
